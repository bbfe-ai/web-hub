# 依赖目录
node_modules/

# 运行时生成的数据（SQLite、截图、日志）
data/
public/screenshots/
logs/
*.log

# 环境变量文件（可能包含敏感信息）
.env
.env.*

# Git / GitHub
.git/
.gitignore
.github/

# Docker 自身配置（镜像内无需再嵌套）
Dockerfile
.dockerignore
docker-compose.yml
docker-compose.*.yml
docker-start.bat
docker-start.sh

# 文档（不进运行镜像）
README.md
CHANGELOG.md
docs/

# 测试与维护脚本
test-*.js
test-*.py
cleanup.js
scripts/

# 根目录临时产物（截图、快照）
*.png
*.jpg
*.jpeg
snap-*.md

# 镜像导出包
*.tar
*.tar.gz

# Claude / 浏览器测试产物
.claude/
.remember/
.playwright-mcp/

# IDE
.vscode/
.idea/
*.swp
*.swo

# 系统文件
.DS_Store
Thumbs.db
